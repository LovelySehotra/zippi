{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@app/contracts": [
        "libs/contracts/src"
      ],
      "@app/contracts/*": [
        "libs/contracts/src/*"
      ],
      "@app/common": [
        "libs/common/src"
      ],
      "@app/common/*": [
        "libs/common/src/*"
      ],
      "@app/messaging": [
        "libs/messaging/src"
      ],
      "@app/messaging/*": [
        "libs/messaging/src/*"
      ],
      "@app/auth": [
        "libs/auth/src"
      ],
      "@app/auth/*": [
        "libs/auth/src/*"
      ],
      "@app/logging": [
        "libs/logging/src"
      ],
      "@app/logging/*": [
        "libs/logging/src/*"
      ],
      "@app/constants": [
        "libs/shared/constants/src"
      ],
      "@app/constants/*": [
        "libs/shared/constants/src/*"
      ],
      "@app/dto": [
        "libs/shared/dto/src"
      ],
      "@app/dto/*": [
        "libs/shared/dto/src/*"
      ],
      "@app/interfaces": [
        "libs/shared/interfaces/src"
      ],
      "@app/interfaces/*": [
        "libs/shared/interfaces/src/*"
      ]
    }
  }
}